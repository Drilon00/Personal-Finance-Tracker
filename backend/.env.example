# Database (NeonDB PostgreSQL)
# DATABASE_URL = the pooled connection (used for queries)
DATABASE_URL="postgresql://username:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
# DIRECT_URL = the direct connection (used for migrations)
DIRECT_URL="postgresql://username:password@host.region.aws.neon.tech/dbname?sslmode=require"

# JWT Secrets (use long random strings in production)
JWT_ACCESS_SECRET="your-access-token-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-token-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV="development"

# CORS
FRONTEND_URL="http://localhost:3000"
